{{ 'jci-home-hero.css' | asset_url | stylesheet_tag }}

<section
  class="jci-home-hero-section color-{{ section.settings.color_scheme }} gradient"
  style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;"
  aria-label="{{ section.settings.heading | default: 'Hero' | escape }}"
>
  <div class="page-width">
    <div class="jci-hero__layout">

      {%- comment -%}────────────────────────────────────
        LEFT COLUMN — HERO CARD
      ────────────────────────────────────{%- endcomment -%}
      <div class="jci-hero__card">

        {%- comment -%} Content Panel {%- endcomment -%}
        <div class="jci-hero__content color-{{ section.settings.hero_content_color_scheme }}">
          <div class="jci-hero__top">
            {%- if section.settings.badge_text != blank -%}
              <span
                class="jci-hero__badge"
                style="background-color: {{ section.settings.badge_bg_color }}; color: {{ section.settings.badge_text_color }};"
              >
                {{- section.settings.badge_text -}}
              </span>
            {%- endif -%}

            <div class="jci-hero__content-body">
              {%- if section.settings.heading != blank -%}
                <h2 class="jci-hero__heading">
                  {{- section.settings.heading | newline_to_br -}}
                </h2>
              {%- endif -%}

              {%- if section.settings.description != blank -%}
                <p class="jci-hero__description">
                  {{- section.settings.description -}}
                </p>
              {%- endif -%}
            </div>
          </div>

          {%- if section.settings.button_label != blank -%}
            <a
              href="{{ section.settings.button_link | default: '#' }}"
              class="jci-hero__cta-btn"
            >
              {{- section.settings.button_label -}}
            </a>
          {%- endif -%}
        </div>

        {%- comment -%} Image Panel {%- endcomment -%}
        <div class="jci-hero__image-panel">
          {%- if section.settings.hero_image != blank -%}
            {{
              section.settings.hero_image
              | image_url: width: 760
              | image_tag:
                loading: 'eager',
                fetchpriority: 'high',
                widths: '375, 550, 760',
                sizes: '(min-width: 990px) 28vw, (min-width: 750px) 36vw, 100vw',
                class: 'jci-hero__img',
                alt: section.settings.hero_image.alt | default: section.settings.heading | escape
            }}
          {%- else -%}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'jci-hero__img placeholder-svg' }}
          {%- endif -%}

          {%- if section.settings.show_sale_badge and section.settings.sale_badge_text != blank -%}
            <span
              class="jci-hero__sale-badge"
              style="background-color: {{ section.settings.sale_badge_bg_color }}; color: {{ section.settings.sale_badge_text_color }};"
            >
              {{- section.settings.sale_badge_text -}}
            </span>
          {%- endif -%}
        </div>

      </div>

      {%- comment -%}────────────────────────────────────
        RIGHT COLUMN — PROMO STACK
      ────────────────────────────────────{%- endcomment -%}
      <div class="jci-hero__promo-stack">

        {%- comment -%} Top promo text block {%- endcomment -%}
        {%- if section.settings.promo_heading != blank or section.settings.promo_description != blank -%}
          <div class="jci-hero__promo-text">
            {%- if section.settings.promo_heading != blank -%}
              <p class="jci-hero__promo-heading">{{- section.settings.promo_heading -}}</p>
            {%- endif -%}
            {%- if section.settings.promo_description != blank -%}
              <p class="jci-hero__promo-desc">{{- section.settings.promo_description -}}</p>
            {%- endif -%}
            {%- if section.settings.promo_link_label != blank -%}
              <a href="{{ section.settings.promo_link_url | default: '#' }}" class="jci-hero__promo-link">
                {{- section.settings.promo_link_label -}}&nbsp;<span aria-hidden="true">→</span>
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- comment -%} Promo Card 1 — e.g. Explore Brands {%- endcomment -%}
        <a
          href="{{ section.settings.card1_link | default: '#' }}"
          class="jci-hero__promo-card color-{{ section.settings.cards_color_scheme }}"
          {% if section.settings.card1_title != blank %}
            aria-label="{{ section.settings.card1_title | escape }}"
          {% endif %}
        >
          <div class="jci-hero__promo-card-title-col">
            {%- if section.settings.card1_title != blank -%}
              <span class="jci-hero__promo-card-title">{{- section.settings.card1_title -}}</span>
            {%- endif -%}
          </div>

          <div class="jci-hero__promo-card-content-col">
            {%- if section.settings.card1_description != blank -%}
              <p class="jci-hero__promo-card-desc">{{- section.settings.card1_description -}}</p>
            {%- endif -%}
            <span class="jci-hero__promo-card-arrow" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="46" height="46" viewBox="0 0 46 46" fill="none">
                <path d="M38.3467 13.0641L5.41086 46L0 40.5891L32.932 7.65327H3.907V0H46V42.093H38.3467V13.0641Z" fill="currentColor"/>
              </svg>
            </span>
          </div>
        </a>

        {%- comment -%} Promo Card 2 — e.g. Find by Category {%- endcomment -%}
        <a
          href="{{ section.settings.card2_link | default: '#' }}"
          class="jci-hero__promo-card color-{{ section.settings.cards_color_scheme }}"
          {% if section.settings.card2_title != blank %}
            aria-label="{{ section.settings.card2_title | escape }}"
          {% endif %}
        >
          <div class="jci-hero__promo-card-title-col">
            {%- if section.settings.card2_title != blank -%}
              <span class="jci-hero__promo-card-title">{{- section.settings.card2_title -}}</span>
            {%- endif -%}
          </div>

          <div class="jci-hero__promo-card-content-col">
            {%- if section.settings.card2_description != blank -%}
              <p class="jci-hero__promo-card-desc">{{- section.settings.card2_description -}}</p>
            {%- endif -%}
            <span class="jci-hero__promo-card-arrow" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="46" height="46" viewBox="0 0 46 46" fill="none">
                <path d="M38.3467 13.0641L5.41086 46L0 40.5891L32.932 7.65327H3.907V0H46V42.093H38.3467V13.0641Z" fill="currentColor"/>
              </svg>
            </span>
          </div>
        </a>

      </div>
      {%- comment -%} end promo stack {%- endcomment -%}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "JCI - Home Hero",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [

    {
      "type": "header",
      "content": "Hero Content"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "Calm & Balance",
      "info": "Leave blank to hide the badge."
    },
    {
      "type": "color",
      "id": "badge_bg_color",
      "label": "Badge background",
      "default": "#BCE599"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Badge text color",
      "default": "#213F22"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Support Your\nBody, Naturally",
      "info": "Use a new line to control where the heading breaks."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Discover premium supplements, wellness essentials, and natural remedies designed to help you feel calmer, stronger, and more balanced every day."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link",
      "default": "/collections/all"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },

    {
      "type": "header",
      "content": "Sale Badge"
    },
    {
      "type": "checkbox",
      "id": "show_sale_badge",
      "label": "Show sale badge",
      "default": true
    },
    {
      "type": "text",
      "id": "sale_badge_text",
      "label": "Sale badge text",
      "default": "ON SALE!"
    },
    {
      "type": "color",
      "id": "sale_badge_bg_color",
      "label": "Sale badge background",
      "default": "#EBF7E1"
    },
    {
      "type": "color",
      "id": "sale_badge_text_color",
      "label": "Sale badge text color",
      "default": "#213F22"
    },

    {
      "type": "header",
      "content": "Right Column — Top Promo Block"
    },
    {
      "type": "text",
      "id": "promo_heading",
      "label": "Promo heading",
      "default": "HealthNook Savings"
    },
    {
      "type": "textarea",
      "id": "promo_description",
      "label": "Promo description",
      "default": "Shop trusted vitamins and wellness essentials at discounted prices."
    },
    {
      "type": "text",
      "id": "promo_link_label",
      "label": "Promo link label",
      "default": "Explore"
    },
    {
      "type": "url",
      "id": "promo_link_url",
      "label": "Promo link URL"
    },

    {
      "type": "header",
      "content": "Right Column — First Card"
    },
    {
      "type": "text",
      "id": "card1_title",
      "label": "Card 1 title",
      "default": "Explore Brands"
    },
    {
      "type": "textarea",
      "id": "card1_description",
      "label": "Card 1 description",
      "default": "Discover Trusted Brands Hand-Picked For Quality And Results."
    },
    {
      "type": "url",
      "id": "card1_link",
      "label": "Card 1 link"
    },
    {
      "type": "image_picker",
      "id": "card1_image",
      "label": "Card 1 image (optional)"
    },

    {
      "type": "header",
      "content": "Right Column — Second Card"
    },
    {
      "type": "text",
      "id": "card2_title",
      "label": "Card 2 title",
      "default": "Find by Category"
    },
    {
      "type": "textarea",
      "id": "card2_description",
      "label": "Card 2 description",
      "default": "Shop by product type and demand."
    },
    {
      "type": "url",
      "id": "card2_link",
      "label": "Card 2 link"
    },
    {
      "type": "image_picker",
      "id": "card2_image",
      "label": "Card 2 image (optional)"
    },

    {
      "type": "header",
      "content": "Color Schemes"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Section background",
      "default": "scheme-10",
      "info": "Applied to the section wrapper."
    },
    {
      "type": "color_scheme",
      "id": "hero_content_color_scheme",
      "label": "Hero content panel",
      "default": "scheme-1",
      "info": "Background and text for the left content panel."
    },
    {
      "type": "color_scheme",
      "id": "promo_block_color_scheme",
      "label": "Promo text block",
      "default": "scheme-5",
      "info": "Top right promo text area."
    },
    {
      "type": "color_scheme",
      "id": "cards_color_scheme",
      "label": "Promo cards",
      "default": "scheme-2",
      "info": "Applied to both right-side promo cards."
    },

    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 68
    }

  ],
  "presets": [
    {
      "name": "JCI - Home Hero"
    }
  ]
}
{% endschema %}