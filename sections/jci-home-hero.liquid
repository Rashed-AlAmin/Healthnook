      "default": "CALM & BALANCE",
      "info": "Leave blank to hide the badge."
    },
    {
      "type": "color",
      "id": "badge_bg_color",
      "label": "Badge background",
      "default": "#BCE599"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Badge text color",
      "default": "#213F22"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Natural Health\nStarts Here"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Discover premium wellness products crafted to support your body and mind."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link",
      "default": "/collections/all"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },

    {
      "type": "header",
      "content": "Sale Badge"
    },
    {
      "type": "checkbox",
      "id": "show_sale_badge",
      "label": "Show sale badge",
