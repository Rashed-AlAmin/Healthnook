{%- style -%}
  #jci-home-hero-{{ section.id }} {
    background-color: #FFFFFF;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .jci-hero__top {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  flex: 1;
}
  
  /* ── Layout ── */
  .jci-hero__layout {
    display: grid;
    grid-template-columns: minmax(0, 2fr) minmax(0, 1fr);
    gap: 1.5rem;
    align-items: stretch;
  }

  /* ── Hero Card (left column) ── */
  .jci-hero__card {
    display: flex;
    flex-direction: row;
    border-radius: 10px;
    overflow: hidden;
  }

  /* Left: content panel — three-zone layout: badge top, text middle, button bottom */
  .jci-hero__content {
  flex: 0 0 53.5%;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 0;
  height: 100%;
  padding: 2.5rem 2rem 2.5rem 2.5rem;
}

  /* Middle zone: heading + description, grows to fill space between badge and button */
  .jci-hero__content-body {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  padding: 0;
}

  /* Hero badge */
  .jci-hero__badge {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    padding: 0.4em 0.85em;
    border-radius: 6px;
    font-size: 0.875em;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    line-height: 1;
  }

  /* Hero heading — scales with Dawn heading scale */
  .jci-hero__heading {
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-size: calc(var(--font-heading-scale) * 3.25rem);
    font-weight: 400;
    line-height: 1.02;
    text-transform: uppercase;
    margin: 0;
    word-break: break-word;
  }

  /* Hero description */
  .jci-hero__description {
    font-family: var(--font-body-family);
    font-size: calc(var(--font-body-scale) * 1rem);
    font-weight: 300;
    line-height: 1.4;
    margin: 0;
    opacity: 0.85;
    max-width: 88%;
  }

  /* Hero CTA button — inherits colors from hero_content color scheme */
  .jci-hero__cta-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 0.9rem 1.5rem;
    border-radius: 6px;
    background-color: rgb(var(--color-button));
    color: rgb(var(--color-button-text));
    font-family: var(--font-body-family);
    font-size: calc(var(--font-body-scale) * 1rem);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .jci-hero__cta-btn:hover,
  .jci-hero__cta-btn:focus-visible {
    opacity: 0.82;
    outline: 0.2rem solid rgba(var(--color-button-text), 0.5);
    outline-offset: 2px;
  }

  /* Right: image panel */
  .jci-hero__image-panel {
    flex: 1 1 0;
    position: relative;
    overflow: hidden;
    min-width: 0;
  }

  .jci-hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Sale badge */
  .jci-hero__sale-badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 1;
    padding: 0.35em 0.75em;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    line-height: 1;
  }

  /* ── Right column: promo stack ── */
  .jci-hero__promo-stack {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* Top promo text block — always white, no color-scheme dependency */
  .jci-hero__promo-text {
    background-color: #FFFFFF;
    border-radius: 8px;
    padding: 1rem 1.25rem 1.125rem;
  }

  .jci-hero__promo-heading {
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-size: 12px;
    font-weight: 500;
    line-height: 18px;
    text-transform: capitalize;
    color: #213F22;
    margin: 0 0 3px;
  }

  .jci-hero__promo-desc {
    font-family: var(--font-body-family);
    font-size: 12px;
    font-weight: 500;
    line-height: 18px;
    text-transform: capitalize;
    color: #213F22;
    margin: 0 0 10px;
  }

  .jci-hero__promo-link {
    font-family: var(--font-body-family);
    font-size: 0.875rem;
    font-weight: 600;
    color: #72AA42;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  .jci-hero__promo-link:hover {
    opacity: 0.7;
  }

  /* Promo cards (Explore Brands / Find by Category) */
  .jci-hero__promo-card {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    flex: 1 1 0;
    min-height: 130px;
    border-radius: 10px;
    overflow: hidden;
    text-decoration: none;
    transition: transform 0.22s ease, box-shadow 0.22s ease;
  }

  .jci-hero__promo-card:hover,
  .jci-hero__promo-card:focus-visible {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(33, 63, 34, 0.14);
    outline: none;
  }

  .jci-hero__promo-card:focus-visible {
    outline: 0.2rem solid rgb(var(--color-foreground));
    outline-offset: 2px;
  }

  /* ── Two-column card layout: title (left) | description + arrow (right) ── */

  /* Left column: large bold title, top-anchored */
  .jci-hero__promo-card-title-col {
    flex: 0 0 44%;
    display: flex;
    align-items: flex-start;
    padding: 20px 12px 20px 22px;
  }

  /* Right column: description at top, arrow 21px below it */
  .jci-hero__promo-card-content-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    padding: 20px 20px 20px 12px;
    min-width: 0;
  }

  .jci-hero__promo-card-title {
    display: block;
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-size: calc(var(--font-heading-scale) * 1.75rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: 0;
    text-transform: uppercase;
    color: rgb(var(--color-foreground));
    word-break: break-word;
  }

  .jci-hero__promo-card-desc {
    font-family: var(--font-body-family);
    font-size: 12px;
    font-weight: 300;
    line-height: 16px;
    margin: 0;
    color: #213F22;
    text-transform: uppercase;
  }

  /* Diagonal NE arrow — 21px below description, right-aligned */
  .jci-hero__promo-card-arrow {
    display: flex;
    align-self: flex-end;
    color: rgb(var(--color-foreground));
    transition: transform 0.2s ease;
    flex-shrink: 0;
    margin-top: 21px;
  }

  .jci-hero__promo-card:hover .jci-hero__promo-card-arrow {
    transform: translate(3px, -3px);
  }

  /* Placeholder SVG fill for hero image panel */
  .jci-hero__image-panel .placeholder-svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* ── Desktop (≥990px) — Figma-matched spacing ── */
  @media screen and (min-width: 990px) {

    /* Exact Figma vertical section spacing */
    #jci-home-hero-{{ section.id }} {
      padding-top: 24px;
      padding-bottom: 68px;
    }

    /* Expand page-width to 1440px (Figma canvas) and apply exact outer spacing.
       Left: 72px, right: 57px (aligns to promo block right edge; cards are 15px inset).
       Overrides Dawn's default page-width padding for this section only. */
    #jci-home-hero-{{ section.id }} .page-width {
      max-width: 1440px;
      padding-left: 72px;
      padding-right: 57px;
    }

    /* Grid: 806fr : 416fr ratio = exact column widths at 1440px viewport.
       align-items: stretch → grid row height = right column's natural content height.
       Hero cell is forced to exactly match the promo stack height — no hardcoded px. */
    .jci-hero__layout {
      grid-template-columns: 806fr 416fr;
      gap: 89px;
      align-items: stretch;
    }

    /* Hero card: no explicit height — grid align-items:stretch makes it fill
       its cell, which equals the right column's natural content height. */
    .jci-hero__card {
      box-shadow: 0px 4px 12px 0px #00000040;
    }

    /* Content panel: 428px of 806px = 53.1% */
    .jci-hero__content {
      flex: 0 0 53.1%;
      /* Figma: top 34px (derived: 500px - 32badge - 30gap - 78h - 14gap - 80desc - 130gap - 50btn - 52pb = 34),
         left/right 28px (button inset), bottom 52px (button → panel bottom) */
      padding: 34px 28px 52px 28px;
    }

    /* Badge: exact Figma 151×32px, 14px/400, no letter-spacing */
    .jci-hero__badge {
      width: 151px;
      height: 32px;
      font-size: 14px;
      font-weight: 400;
      line-height: 1;
      letter-spacing: 0;
      padding: 0 9px;
      justify-content: center;
    }

    /* Badge → heading gap: Figma 30px */
    .jci-hero__top {
      gap: 30px;
    }

    /* Heading: exact Figma 40px / line-height 39px */
    .jci-hero__heading {
      font-size: 40px;
      line-height: 39px;
    }

    /* Heading → description gap: Figma 14px */
    .jci-hero__content-body {
      gap: 14px;
    }

    /* Description: Figma 16px / 20px line-height / capitalize / full opacity */
    .jci-hero__description {
      font-size: 16px;
      line-height: 20px;
      text-transform: capitalize;
      opacity: 1;
      max-width: 100%;
    }

    /* CTA button: exact Figma 372×50px (width=100% fits within 28px panel insets) */
    .jci-hero__cta-btn {
      height: 50px;
      font-size: 16px;
      line-height: 1;
      padding-top: 0;
      padding-bottom: 0;
    }

    /* Sale badge: exact Figma 85×26px, top 15px / right 22px, 12px/400, centered */
    .jci-hero__sale-badge {
      top: 15px;
      right: 22px;
      width: 85px;
      height: 26px;
      font-size: 12px;
      font-weight: 400;
      line-height: 1;
      letter-spacing: 0;
      text-transform: none;
      padding: 0;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    /* Right column: individual margins replace the uniform gap so each spacing
       zone can be set independently.
       promo-text → card1: 31px (margin-bottom on promo-text)
       card1 → card2: 29px (margin-top on second card via adjacent sibling) */
    .jci-hero__promo-stack {
      gap: 0;
    }

    /* Promo text block: no padding at desktop — block height equals the raw text
       stack (29 + 3 + 18 + 10 + 18 = 78px), keeping the right column at ~500px total. */
    .jci-hero__promo-text {
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
      padding: 0;
      margin-bottom: 31px;
    }

    /* Promo heading: Figma spec — 20px / weight 300 / 39px line-height / uppercase / #213F22 */
    .jci-hero__promo-heading {
      font-size: 20px;
      font-weight: 300;
      line-height: 39px;
      text-transform: uppercase;
      color: #213F22;
      margin: 0 0 3px;
    }

    /* Desc: 12px / weight 500 / 18px line-height / capitalize / #213F22 (inherits base) */
    .jci-hero__promo-desc {
      line-height: 18px;
      margin: 0 0 10px;
    }

    /* "Explore" link: 14px / weight 500 / 18px line-height / capitalize / #72AA42 */
    .jci-hero__promo-link {
      font-size: 14px;
      font-weight: 500;
      line-height: 18px;
      text-transform: capitalize;
      color: #72AA42;
    }

    /* Promo cards: min-height instead of fixed height so content can grow the card.
       flex: 1 1 auto → cards share available space equally when extra height exists.
       max-width: calc(100% - 15px) → right edge sits 72px from page right
       (57px section padding + 15px inset), matching the left panel's 72px left inset.
       gap: 31px → spacing between title-col and content-col inside the card. */
    .jci-hero__promo-card {
      flex: 1 1 auto;
      min-height: 181px;
      max-width: calc(100% - 15px);
      gap: 31px;
    }

    /* Gap between the two promo cards: 29px */
    .jci-hero__promo-card + .jci-hero__promo-card {
      margin-top: 29px;
    }

    .jci-hero__promo-card-title-col {
      flex: 0 0 44%;
      padding: 52px 0 20px 26px;
    }

    /* Content col:
       - position: relative → anchor for the absolutely positioned arrow
       - top 60px  → desc starts 60px from card top (8px below title-col's 52px = Figma offset)
       - right 40px → text has 40px breathing room from card right edge
       - bottom 22px → inner clearance below text (arrow is absolute, not in flow)
       - justify-content: flex-start → text anchors to top of its zone */
    .jci-hero__promo-card-content-col {
      position: relative;
      justify-content: flex-start;
      padding: 60px 40px 22px 0;
    }

    /* Title: explicit 28px — wraps "EXPLORE BRANDS" to 2 lines in the 44% column */
    .jci-hero__promo-card-title {
      font-size: 28px;
      line-height: 1.0;
    }

    .jci-hero__promo-card-desc {
      font-size: 12px;
      line-height: 16px;
    }

    /* Arrow: absolutely positioned — decoupled from text flow.
       right: 29px → arrow right edge 29px from card right
       bottom: 22px → arrow bottom edge 22px from card bottom
       margin-top: 0 → resets the base 21px (not needed with absolute positioning) */
    .jci-hero__promo-card-arrow {
      position: absolute;
      right: 29px;
      bottom: 22px;
      width: 46px;
      height: 46px;
      margin-top: 0;
    }

  }

  /* ── Tablet (750–989px) ── */
  @media screen and (min-width: 750px) and (max-width: 989px) {
    .jci-hero__layout {
      gap: 1rem;
    }

    .jci-hero__content {
      padding: 1.75rem 1.25rem 1.75rem 1.5rem;
    }

    .jci-hero__content-body {
      gap: 0.625rem;
    }

    .jci-hero__heading {
      font-size: calc(var(--font-heading-scale) * 2.25rem);
    }

    .jci-hero__card {
      min-height: 380px;
    }

    .jci-hero__promo-card {
      min-height: 110px;
    }
  }

  /* ── Mobile (≤749px) ── */
  @media screen and (max-width: 749px) {
    .jci-hero__layout {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    /* Stack hero card: image on top, content below */
    .jci-hero__card {
      flex-direction: column;
      min-height: unset;
      border-radius: 10px;
    }

    .jci-hero__image-panel {
      order: -1;
      flex: 0 0 auto;
      min-height: 240px;
    }

    .jci-hero__content {
      flex: unset;
      padding: 1.75rem 1.5rem;
    }

    .jci-hero__content-body {
      gap: 0.625rem;
    }

    .jci-hero__heading {
      font-size: calc(var(--font-heading-scale) * 2rem);
    }

    /* Full-width CTA on mobile */
    .jci-hero__cta-btn {
      width: 100%;
    }

    /* Promo cards: slightly shorter on mobile */
    .jci-hero__promo-card {
      min-height: 110px;
    }
  }
{%- endstyle -%}

<section
  id="jci-home-hero-{{ section.id }}"
  class="jci-home-hero color-{{ section.settings.color_scheme }} gradient"
  aria-label="{{ section.settings.heading | default: 'Hero' | escape }}"
>
  <div class="page-width">
    <div class="jci-hero__layout">

      {%- comment -%}────────────────────────────────────
        LEFT COLUMN — HERO CARD
      ────────────────────────────────────{%- endcomment -%}
      <div class="jci-hero__card">

        {%- comment -%} Content Panel {%- endcomment -%}
        <div class="jci-hero__content color-{{ section.settings.hero_content_color_scheme }}">
          <div class="jci-hero__top">
            {%- if section.settings.badge_text != blank -%}
              <span
                class="jci-hero__badge"
                style="background-color: {{ section.settings.badge_bg_color }}; color: {{ section.settings.badge_text_color }};"
              >
                {{- section.settings.badge_text -}}
              </span>
            {%- endif -%}

            <div class="jci-hero__content-body">
              {%- if section.settings.heading != blank -%}
                <h2 class="jci-hero__heading">
                  {{- section.settings.heading | newline_to_br -}}
                </h2>
              {%- endif -%}

              {%- if section.settings.description != blank -%}
                <p class="jci-hero__description">
                  {{- section.settings.description -}}
                </p>
              {%- endif -%}
            </div>
          </div>

          {%- if section.settings.button_label != blank -%}
            <a
              href="{{ section.settings.button_link | default: '#' }}"
              class="jci-hero__cta-btn"
            >
              {{- section.settings.button_label -}}
            </a>
          {%- endif -%}
        </div>

        {%- comment -%} Image Panel {%- endcomment -%}
        <div class="jci-hero__image-panel">
          {%- if section.settings.hero_image != blank -%}
            {{
              section.settings.hero_image
              | image_url: width: 760
              | image_tag:
                loading: 'eager',
                fetchpriority: 'high',
                widths: '375, 550, 760',
                sizes: '(min-width: 990px) 28vw, (min-width: 750px) 36vw, 100vw',
                class: 'jci-hero__img',
                alt: section.settings.hero_image.alt | default: section.settings.heading | escape
            }}
          {%- else -%}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'jci-hero__img placeholder-svg' }}
          {%- endif -%}

          {%- if section.settings.show_sale_badge and section.settings.sale_badge_text != blank -%}
            <span
              class="jci-hero__sale-badge"
              style="background-color: {{ section.settings.sale_badge_bg_color }}; color: {{ section.settings.sale_badge_text_color }};"
            >
              {{- section.settings.sale_badge_text -}}
            </span>
          {%- endif -%}
        </div>

      </div>

      {%- comment -%}────────────────────────────────────
        RIGHT COLUMN — PROMO STACK
      ────────────────────────────────────{%- endcomment -%}
      <div class="jci-hero__promo-stack">

        {%- comment -%} Top promo text block {%- endcomment -%}
        {%- if section.settings.promo_heading != blank or section.settings.promo_description != blank -%}
          <div class="jci-hero__promo-text">
            {%- if section.settings.promo_heading != blank -%}
              <p class="jci-hero__promo-heading">{{- section.settings.promo_heading -}}</p>
            {%- endif -%}
            {%- if section.settings.promo_description != blank -%}
              <p class="jci-hero__promo-desc">{{- section.settings.promo_description -}}</p>
            {%- endif -%}
            {%- if section.settings.promo_link_label != blank -%}
              <a href="{{ section.settings.promo_link_url | default: '#' }}" class="jci-hero__promo-link">
                {{- section.settings.promo_link_label -}}&nbsp;<span aria-hidden="true">→</span>
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- comment -%} Promo Card 1 — e.g. Explore Brands {%- endcomment -%}
        <a
          href="{{ section.settings.card1_link | default: '#' }}"
          class="jci-hero__promo-card color-{{ section.settings.cards_color_scheme }}"
          {% if section.settings.card1_title != blank %}
            aria-label="{{ section.settings.card1_title | escape }}"
          {% endif %}
        >
          <div class="jci-hero__promo-card-title-col">
            {%- if section.settings.card1_title != blank -%}
              <span class="jci-hero__promo-card-title">{{- section.settings.card1_title -}}</span>
            {%- endif -%}
          </div>

          <div class="jci-hero__promo-card-content-col">
            {%- if section.settings.card1_description != blank -%}
              <p class="jci-hero__promo-card-desc">{{- section.settings.card1_description -}}</p>
            {%- endif -%}
            <span class="jci-hero__promo-card-arrow" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="46" height="46" viewBox="0 0 46 46" fill="none">
                <path d="M38.3467 13.0641L5.41086 46L0 40.5891L32.932 7.65327H3.907V0H46V42.093H38.3467V13.0641Z" fill="currentColor"/>
              </svg>
            </span>
          </div>
        </a>

        {%- comment -%} Promo Card 2 — e.g. Find by Category {%- endcomment -%}
        <a
          href="{{ section.settings.card2_link | default: '#' }}"
          class="jci-hero__promo-card color-{{ section.settings.cards_color_scheme }}"
          {% if section.settings.card2_title != blank %}
            aria-label="{{ section.settings.card2_title | escape }}"
          {% endif %}
        >
          <div class="jci-hero__promo-card-title-col">
            {%- if section.settings.card2_title != blank -%}
              <span class="jci-hero__promo-card-title">{{- section.settings.card2_title -}}</span>
            {%- endif -%}
          </div>

          <div class="jci-hero__promo-card-content-col">
            {%- if section.settings.card2_description != blank -%}
              <p class="jci-hero__promo-card-desc">{{- section.settings.card2_description -}}</p>
            {%- endif -%}
            <span class="jci-hero__promo-card-arrow" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="46" height="46" viewBox="0 0 46 46" fill="none">
                <path d="M38.3467 13.0641L5.41086 46L0 40.5891L32.932 7.65327H3.907V0H46V42.093H38.3467V13.0641Z" fill="currentColor"/>
              </svg>
            </span>
          </div>
        </a>

      </div>
      {%- comment -%} end promo stack {%- endcomment -%}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "JCI - Home Hero",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [

    {
      "type": "header",
      "content": "Hero Content"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "Calm & Balance",
      "info": "Leave blank to hide the badge."
    },
    {
      "type": "color",
      "id": "badge_bg_color",
      "label": "Badge background",
      "default": "#BCE599"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Badge text color",
      "default": "#213F22"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Support Your\nBody, Naturally",
