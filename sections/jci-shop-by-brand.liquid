{{ 'jci-shop-by-brand.css' | asset_url | stylesheet_tag }}
{{ 'jci-navigate-by-product-feature.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  ══════════════════════════════════════════════════════
  JCI - Shop By Brand / Navigate By Product Features
  sections/jci-shop-by-brand.liquid

  This ONE section supports TWO use cases via block types:
  ─ "image_card" → brand logo card (image + link)
  ─ "text_icon"  → feature card (abbreviation + label + icon)

  To make a second section (e.g. "Navigate By Product Features"):
  1. Duplicate this section file and rename it.
  2. Add blocks of type "text_icon" in the Theme Editor.
  3. Set the same "Tab group" value on blocks that share a tab.

  Block grouping:
  Each block has a `group_title` field. Blocks with the same
  group_title appear under the same tab. Tabs are auto-generated
  from unique group_title values in block order.
  ══════════════════════════════════════════════════════
{%- endcomment -%}

{%- comment -%} Collect unique group titles in block order {%- endcomment -%}
{%- assign _group_list = '' -%}
{%- for block in section.blocks -%}
  {%- assign _g = block.settings.group_title | strip -%}
  {%- if _g != blank -%}
    {%- assign _already = false -%}
    {%- if _group_list != '' -%}
      {%- assign _check = _group_list | split: '~~~' -%}
      {%- for _item in _check -%}
        {%- if _item == _g -%}{%- assign _already = true -%}{%- endif -%}
      {%- endfor -%}
    {%- endif -%}
    {%- unless _already -%}
      {%- if _group_list == '' -%}
        {%- assign _group_list = _g -%}
      {%- else -%}
        {%- assign _group_list = _group_list | append: '~~~' | append: _g -%}
      {%- endif -%}
    {%- endunless -%}
  {%- endif -%}
{%- endfor -%}
{%- assign _groups = _group_list | split: '~~~' -%}

<section
  class="jci-shop-brand {% if section.settings.section_mode == 'feature' %}jci-product-features{% endif %} color-{{ section.settings.color_scheme }} gradient"
  id="jci-shop-brand-{{ section.id }}"
  data-section-id="{{ section.id }}"
  style="
    --section-pt: {{ section.settings.padding_top }}px;
    --section-pb: {{ section.settings.padding_bottom }}px;
    {%- if section.settings.show_top_divider -%}
      border-top: {{ section.settings.divider_thickness }}px solid #213F22;
    {%- endif -%}
    {%- if section.settings.show_bottom_divider -%}
      border-bottom: {{ section.settings.divider_thickness }}px solid #213F22;
    {%- endif -%}
  "
  aria-label="{{ section.settings.heading | default: 'Shop By Brand' | escape }}"
>
  <div class="page-width">

    {%- comment -%}── HEADER: heading + tabs ──{%- endcomment -%}
    <div class="jci-shop-brand__header">

      {%- if section.settings.heading != blank -%}
        <h2 class="jci-shop-brand__heading">
          {{- section.settings.heading | escape -}}
        </h2>
      {%- endif -%}

      {%- if _groups.size > 0 and section.settings.section_mode == 'brand' -%}
        <div
          class="jci-shop-brand__tabs{% if _groups.size == 1 %} hidden{% endif %}"
          role="tablist"
          aria-label="{{ section.settings.heading | default: 'Shop By Brand' | escape }}"
        >
          {%- for _group in _groups -%}
            <button
              class="jci-shop-brand__tab{% if forloop.first %} jci-shop-brand__tab--active{% endif %}"
              role="tab"
              type="button"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              data-tab="{{ _group | escape }}"
            >
              {{- _group | upcase | escape -}}
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}

    </div>
    {%- comment -%}── /header ──{%- endcomment -%}

    {%- comment -%}── LOGO / CARD GRID ──{%- endcomment -%}
    <div
      class="jci-shop-brand__logos"
      role="tabpanel"
      data-section-id="{{ section.id }}"
    >

      {%- for block in section.blocks -%}
        {%- assign _g = block.settings.group_title | strip -%}

        {%- comment -%}
          Every block — regardless of type — is wrapped in the same
          jci-shop-brand__logo-item div so that:
          • The [hidden] attribute hides it when its tab is inactive
          • The carousel JS can manage it on mobile
        {%- endcomment -%}
        {%- comment -%}
       <div
          class="jci-shop-brand__logo-item{% if block.settings.highlight %} jci-shop-brand__logo-item--highlighted{% endif %}"
          data-group="{{ _g | escape }}"
          {% unless _g == _groups.first %}hidden{% endunless %}
          {{ block.shopify_attributes }}
        > 
          {%- endcomment -%}
          <div
            class="jci-shop-brand__logo-item{% if block.type == 'image_card' %} jci-shop-brand__logo-item--image{% endif %}{% if block.type == 'text_icon' %} jci-shop-brand__logo-item--ti{% endif %}{% if block.settings.highlight %} jci-shop-brand__logo-item--highlighted{% endif %}"
            data-group="{{ _g | escape }}"
            {% unless _g == _groups.first %}hidden{% endunless %}
            {{ block.shopify_attributes }}
          >
          {%- if block.type == 'text_icon' -%}

            {%- comment -%}── TEXT ICON card (Navigate By Product Features) ──{%- endcomment -%}
            {%- if block.settings.link != blank -%}
              <a href="{{ block.settings.link }}" class="jci-shop-brand__logo-link jci-shop-brand__logo-link--ti"
                 {% if block.settings.label != blank %}aria-label="{{ block.settings.label | escape }}"{% endif %}>
            {%- else -%}
              <div class="jci-shop-brand__logo-link jci-shop-brand__logo-link--ti">
            {%- endif -%}

              <span class="jci-ti__left">
                {%- if block.settings.abbreviation != blank -%}
                  <span class="jci-ti__abbr">{{- block.settings.abbreviation | escape | upcase -}}</span>
                {%- endif -%}
                {%- if block.settings.label != blank -%}
                  <span class="jci-ti__label">{{- block.settings.label | escape -}}</span>
                {%- endif -%}
              </span>

              {%- if block.settings.icon != blank -%}
                <img
                  class="jci-ti__icon"
                  src="{{ block.settings.icon | image_url: width: 80 }}"
                  alt=""
                  width="40"
                  height="40"
                  loading="lazy"
                >
              {%- endif -%}

            {%- if block.settings.link != blank -%}
              </a>
            {%- else -%}
              </div>
            {%- endif -%}

          {%- else -%}

            {%- comment -%}── IMAGE CARD (Shop By Brand logo) ──{%- endcomment -%}
            {%- if block.settings.link != blank -%}
              <a href="{{ block.settings.link }}" class="jci-shop-brand__logo-link"
                 aria-label="{{ block.settings.brand_name | default: 'Brand' | escape }}">
            {%- else -%}
              <div class="jci-shop-brand__logo-link">
            {%- endif -%}

              {%- if block.settings.logo != blank -%}
                {{
                  block.settings.logo
                  | image_url: width: 614
                  | image_tag:
                    loading: 'lazy',
                    widths: '307, 614',
                    sizes: '307px',
                    class: 'jci-shop-brand__logo-img',
                    alt: block.settings.brand_name | default: block.settings.logo.alt | escape
                }}
              {%- elsif block.settings.brand_name != blank -%}
                <span class="jci-shop-brand__logo-placeholder">{{- block.settings.brand_name | escape -}}</span>
              {%- else -%}
                <span class="jci-shop-brand__logo-placeholder">Brand</span>
              {%- endif -%}

            {%- if block.settings.link != blank -%}
              </a>
            {%- else -%}
              </div>
            {%- endif -%}

          {%- endif -%}

        </div>
        {%- comment -%}── /logo-item ──{%- endcomment -%}

      {%- endfor -%}

      {%- if section.blocks.size == 0 -%}
        <p class="jci-shop-brand__empty">
          Add <strong>Brand Logo</strong> or <strong>Text Icon</strong> blocks in the theme editor to get started.
        </p>
      {%- endif -%}

    </div>
    {%- comment -%}── /logos ──{%- endcomment -%}

    {%- comment -%}── MOBILE CAROUSEL CONTROLS ──{%- endcomment -%}
    {% if section.settings.section_mode == 'brand' %}
      <div
        class="jci-shop-brand__controls jci-shop-brand__controls--hidden"
        aria-label="Browse items"
        data-section-id="{{ section.id }}"
      >
        <button class="jci-shop-brand__arrow jci-shop-brand__arrow--prev" type="button" aria-label="Previous">
          <svg xmlns="http://www.w3.org/2000/svg" width="11" height="10" viewBox="0 0 11 10" fill="none" aria-hidden="true" focusable="false">
            <path d="M9.5 5H1.5M1.5 5L5.5 9M1.5 5L5.5 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button class="jci-shop-brand__arrow jci-shop-brand__arrow--next" type="button" aria-label="Next">
          <svg xmlns="http://www.w3.org/2000/svg" width="11" height="10" viewBox="0 0 11 10" fill="none" aria-hidden="true" focusable="false">
            <path d="M1.5 5H9.5M9.5 5L5.5 1M9.5 5L5.5 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    {% endif %}

    {%- comment -%}── VIEW ALL BUTTON ──{%- endcomment -%}
    {%- if section.settings.show_view_all and section.settings.view_all_label != blank -%}
      <div class="jci-shop-brand__viewall">
        {%- if section.settings.section_mode == 'feature' -%}
          {%- comment -%}
            Feature mode: expand/collapse toggle.
            JS picks up .jci-feature-toggle-btn and the data-* attributes.
            The <button> uses the same visual class as the brand <a> link.
          {%- endcomment -%}
          <button
            type="button"
            class="jci-shop-brand__viewall-btn jci-feature-toggle-btn"
            data-label-more="{{ section.settings.view_all_label | escape }}"
            data-label-less="{{ section.settings.view_less_label | default: 'View Less' | escape }}"
            data-desktop-limit="12"
            data-mobile-limit="3"
            aria-expanded="false"
          >
            {{- section.settings.view_all_label | escape -}}
          </button>
        {%- else -%}
          {%- comment -%}Brand mode: plain link to a page (unchanged).{%- endcomment -%}
          <a href="{{ section.settings.view_all_url | default: '#' }}" class="jci-shop-brand__viewall-btn">
            {{- section.settings.view_all_label | escape -}}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

  </div>
</section>

{% if section.settings.section_mode == 'brand' %}
  <script src="{{ 'jci-shop-by-brand.js' | asset_url }}" defer></script>
{% endif %}
{% if section.settings.section_mode == 'feature' %}
  <script src="{{ 'jci-navigate-by-product-feature.js' | asset_url }}" defer></script>
{% endif %}

{% schema %}
{
  "name": "JCI - Shop By Brand",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "max_blocks": 60,
  "settings": [
    
    {
      "type": "select",
      "id": "section_mode",
      "label": "Section type",
      "options": [
        { "value": "brand", "label": "Shop by Brand" },
        { "value": "feature", "label": "Navigate by Product Features" }
      ],
      "default": "brand"
    },
    {
      "type": "header",
      "content": "Section Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop By Brand"
    },
    {
      "type": "header",
      "content": "Section Style"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Dividers"
    },
    {
      "type": "checkbox",
      "id": "show_top_divider",
      "label": "Show top divider",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_bottom_divider",
      "label": "Show bottom divider",
      "default": true
    },
    {
      "type": "range",
      "id": "divider_thickness",
      "min": 1,
      "max": 3,
      "step": 1,
      "unit": "px",
      "label": "Divider thickness",
      "default": 1
    },
    {
      "type": "header",
      "content": "View All Button"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show View All button",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "Button label",
      "default": "View All Brands"
    },
    {
      "type": "text",
      "id": "view_less_label",
      "label": "View Less label (feature mode only)",
      "default": "View Less",
      "info": "Only used in Navigate by Product Features mode for the collapse button."
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": "Button link (brand mode only)"
    },
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "image_card",
      "name": "Brand Logo",
      "settings": [
        {
          "type": "text",
          "id": "group_title",
          "label": "Tab group",
          "default": "A TO C",
          "info": "Brands sharing the same Tab group appear under the same tab. Must match exactly — same capitalisation."
        },
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Brand logo image"
        },
        {
          "type": "text",
          "id": "brand_name",
          "label": "Brand name / alt text",
          "info": "Used as image alt text and shown as fallback if no logo is uploaded."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Brand link (optional)"
        }
      ]
    },
    {
      "type": "text_icon",
      "name": "Text Icon Card",
      "settings": [
        {
          "type": "text",
          "id": "group_title",
          "label": "Tab group",
          "default": "ALL",
          "info": "Cards sharing the same Tab group appear under the same tab. Use a single group (e.g. ALL) to show all cards with no tabs."
        },
        {
          "type": "text",
          "id": "abbreviation",
          "label": "Abbreviation",
          "info": "2–3 letter code displayed large on the left (e.g. CO, GF, DF).",
          "default": "CO"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "info": "Full text shown beside the abbreviation (e.g. Certified Organic).",
          "default": "Certified Organic"
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon image",
          "info": "Small icon shown on the right side of the card."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        },
        {
          "type": "checkbox",
          "id": "highlight",
          "label": "Highlight this card",
          "default": false,
          "info": "Adds a dark background to make this card stand out (e.g. active/featured state)."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "JCI - Shop By Brand",
      "blocks": [
        { "type": "image_card", "settings": { "group_title": "A TO C", "brand_name": "Brand One" } },
        { "type": "image_card", "settings": { "group_title": "A TO C", "brand_name": "Brand Two" } },
        { "type": "image_card", "settings": { "group_title": "A TO C", "brand_name": "Brand Three" } },
        { "type": "image_card", "settings": { "group_title": "A TO C", "brand_name": "Brand Four" } },
        { "type": "image_card", "settings": { "group_title": "D TO I", "brand_name": "Brand Five" } },
        { "type": "image_card", "settings": { "group_title": "D TO I", "brand_name": "Brand Six" } }
      ]
    }
  ]
}
{% endschema %}
