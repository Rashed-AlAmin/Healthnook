{{ 'jci-shop-by-category.css' | asset_url | stylesheet_tag }}

<section
  class="jci-shop-cat color-{{ section.settings.color_scheme }} gradient"
  id="jci-shop-cat-{{ section.id }}"
  style="--section-pt: {{ section.settings.padding_top }}px; --section-pb: {{ section.settings.padding_bottom }}px;"
  aria-label="{{ section.settings.heading | default: 'Shop By Category' | escape }}"
>
  <div class="page-width">

    {%- if section.settings.heading != blank -%}
      <h2 class="jci-shop-cat__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="jci-shop-cat__grid">

        {%- for block in section.blocks -%}
          {%- assign col        = block.settings.collection -%}
          {%- assign card_title = block.settings.title_override | default: col.title | default: 'Category' -%}
          {%- assign card_url   = col.url | default: '#' -%}

          <a
            href="{{ card_url }}"
            class="jci-shop-cat__card"
            {{ block.shopify_attributes }}
            aria-label="{{ card_title | escape }}"
          >
            <h3 class="jci-shop-cat__title">{{ card_title | escape }}</h3>

            <div class="jci-shop-cat__footer">
              <span class="jci-shop-cat__arrow" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 11 11" fill="none">
                  <path d="M3.5 2L8 5.5L3.5 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>

              {%- if block.settings.icon != blank -%}
                <img
                  class="jci-shop-cat__icon"
                  src="{{ block.settings.icon | image_url: width: 160 }}"
                  alt="{{ block.settings.icon_alt | default: '' }}"
                  width="80"
                  height="80"
                  loading="lazy"
                  draggable="false"
                >
              {%- endif -%}
            </div>
          </a>

        {%- endfor -%}

      </div>
    {%- else -%}
      <p class="jci-shop-cat__empty">
        Add <strong>Category Card</strong> blocks in the theme editor to get started.
      </p>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "JCI - Shop By Category",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "max_blocks": 8,
  "settings": [
    {
      "type": "header",
      "content": "Section Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop By Category"
    },
    {
      "type": "header",
      "content": "Section Style"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-5"
    },
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "category_card",
      "name": "Category Card",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "title_override",
          "label": "Title override",
          "info": "Optional. Overrides the collection title shown on the card."
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Category icon",
          "info": "Use a dark line-art PNG or SVG for best hover effect."
        },
        {
          "type": "text",
          "id": "icon_alt",
          "label": "Icon alt text",
          "info": "Optional. Leave blank to hide from screen readers."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "JCI - Shop By Category",
      "blocks": [
        { "type": "category_card" },
        { "type": "category_card" },
        { "type": "category_card" },
        { "type": "category_card" },
        { "type": "category_card" },
        { "type": "category_card" },
        { "type": "category_card" },
        { "type": "category_card" }
      ]
    }
  ]
}
{% endschema %}
