    {
      "type": "url",
      "id": "social_linkedin",
      "label": "LinkedIn URL"
    },
    {
      "type": "url",
      "id": "social_youtube",
      "label": "YouTube URL"
    },
    {
      "type": "url",
      "id": "social_twitter",
      "label": "Twitter / X URL"
    },
    {
      "type": "header",
      "content": "Legal bar"
    },
    {
      "type": "text",
      "id": "copyright",
