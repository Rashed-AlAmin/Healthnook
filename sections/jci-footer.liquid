{{ 'jci-footer.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .jci-footer-{{ section.id }} {
    --jci-f-contact-bg: {{ section.settings.contact_card_bg }};
    --jci-f-logo-max: {{ section.settings.logo_max_width }}px;
  }
{%- endstyle -%}

<div class="jci-footer jci-footer-{{ section.id }} color-{{ section.settings.color_scheme }} gradient">

  {%- comment -%}======================================================
    PART 1 — TOP CONTENT AREA
  ======================================================{%- endcomment -%}
  <div class="jci-footer__top">
    <div class="jci-footer__wrap">
      <div class="jci-footer__top-grid">

        {%- comment -%}---- LEFT: Newsletter ----{%- endcomment -%}
        <div class="jci-footer__col jci-footer__col--newsletter">

          {%- unless section.settings.newsletter_eyebrow == blank -%}
            <p class="jci-footer__eyebrow">{{ section.settings.newsletter_eyebrow }}</p>
          {%- endunless -%}

          {%- unless section.settings.newsletter_heading == blank -%}
            <h2 class="jci-footer__nl-heading">{{ section.settings.newsletter_heading }}</h2>
          {%- endunless -%}

          {%- unless section.settings.newsletter_privacy_text == blank -%}
            <p class="jci-footer__privacy">
              {{- section.settings.newsletter_privacy_text -}}
              {%- if section.settings.newsletter_privacy_link_label != blank -%}
                {%- if section.settings.newsletter_privacy_link_url != blank -%}
                  &nbsp;<a href="{{ section.settings.newsletter_privacy_link_url }}" class="jci-footer__privacy-link">{{ section.settings.newsletter_privacy_link_label }}</a>
                {%- else -%}
                  &nbsp;{{ section.settings.newsletter_privacy_link_label }}
                {%- endif -%}
              {%- endif -%}
            </p>
          {%- endunless -%}

          {%- form 'customer', id: 'jci-nl-{{ section.id }}', class: 'jci-footer__nl-form' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">

            {%- if form.posted_successfully? -%}
              <p class="jci-footer__nl-success" role="status">
                {{ section.settings.newsletter_success | default: 'Thank you for subscribing!' }}
              </p>
            {%- else -%}
              <div class="jci-footer__nl-row">
                <label for="jci-nl-email-{{ section.id }}" class="visually-hidden">
                  {{ section.settings.newsletter_placeholder | default: 'Newsletter sign-up...' }}
                </label>
                <input
                  class="jci-footer__nl-input"
                  type="email"
                  name="contact[email]"
                  id="jci-nl-email-{{ section.id }}"
                  value="{{ form.email }}"
                  placeholder="{{ section.settings.newsletter_placeholder | default: 'Newsletter sign-up...' }}"
                  autocomplete="email"
                  autocorrect="off"
                  autocapitalize="off"
                  {%- if form.errors contains 'email' %}
                    aria-invalid="true"
                    aria-describedby="jci-nl-err-{{ section.id }}"
                  {%- endif %}
                >
                <button type="submit" class="jci-footer__nl-btn">
                  {{ section.settings.newsletter_button | default: 'SUBSCRIBE' }}
                </button>
              </div>

              {%- if form.errors -%}
                <p id="jci-nl-err-{{ section.id }}" class="jci-footer__nl-error" role="alert">
                  {{ form.errors | default_errors }}
                </p>
              {%- endif -%}
            {%- endif -%}
          {%- endform -%}

        </div>

        {%- comment -%}---- MIDDLE: Shopping Links ----{%- endcomment -%}
        <div class="jci-footer__col jci-footer__col--links">

          {%- unless section.settings.links_heading == blank -%}
            <h3 class="jci-footer__links-heading">{{ section.settings.links_heading }}</h3>
          {%- endunless -%}

          {%- if section.blocks.size > 0 -%}
            <ul class="jci-footer__links-list" role="list">
              {%- for block in section.blocks -%}
                {%- if block.type == 'nav_link' -%}
                  <li {{ block.shopify_attributes }}>
                    {%- if block.settings.url != blank -%}
                      <a href="{{ block.settings.url }}" class="jci-footer__link">
                        {{- block.settings.label -}}
                      </a>
                    {%- else -%}
                      <span class="jci-footer__link">{{ block.settings.label }}</span>
                    {%- endif -%}
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          {%- endif -%}

        </div>

        {%- comment -%}---- RIGHT: Contact Card ----{%- endcomment -%}
        <div class="jci-footer__col jci-footer__col--contact">
          <div class="jci-footer__contact-card" style="background-color: var(--jci-f-contact-bg, #D8F3DC);">

            {%- unless section.settings.contact_heading == blank -%}
              <h3 class="jci-footer__contact-heading">{{ section.settings.contact_heading }}</h3>
            {%- endunless -%}

            <ul class="jci-footer__contact-list" role="list">

              {%- unless section.settings.contact_phone_display == blank -%}
                <li class="jci-footer__contact-item">
                  <span class="jci-footer__contact-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.62 3.38 2 2 0 0 1 3.59 1h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.56a16 16 0 0 0 6.29 6.29l.87-.87a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                    </svg>
                  </span>
                  {%- if section.settings.contact_phone_href != blank -%}
                    <a href="{{ section.settings.contact_phone_href }}" class="jci-footer__contact-text">
                      {{- section.settings.contact_phone_display -}}
                    </a>
                  {%- else -%}
                    <span class="jci-footer__contact-text">{{ section.settings.contact_phone_display }}</span>
                  {%- endif -%}
                </li>
              {%- endunless -%}

              {%- unless section.settings.contact_email_display == blank -%}
                <li class="jci-footer__contact-item">
                  <span class="jci-footer__contact-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                      <polyline points="22,6 12,13 2,6"/>
                    </svg>
                  </span>
                  {%- if section.settings.contact_email_href != blank -%}
                    <a href="{{ section.settings.contact_email_href }}" class="jci-footer__contact-text">
                      {{- section.settings.contact_email_display -}}
                    </a>
                  {%- else -%}
                    <span class="jci-footer__contact-text">{{ section.settings.contact_email_display }}</span>
                  {%- endif -%}
                </li>
              {%- endunless -%}

              {%- unless section.settings.contact_store_label == blank -%}
                <li class="jci-footer__contact-item">
                  <span class="jci-footer__contact-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                      <circle cx="12" cy="10" r="3"/>
                    </svg>
                  </span>
                  {%- if section.settings.contact_store_url != blank -%}
                    <a href="{{ section.settings.contact_store_url }}" class="jci-footer__contact-text">
                      {{- section.settings.contact_store_label -}}
                    </a>
                  {%- else -%}
                    <span class="jci-footer__contact-text">{{ section.settings.contact_store_label }}</span>
                  {%- endif -%}
                </li>
              {%- endunless -%}

            </ul>
          </div>
        </div>

      </div>
    </div>
  </div>

  {%- comment -%}====== DIVIDER 1 ======{%- endcomment -%}
  <div class="jci-footer__divider"></div>

  {%- comment -%}======================================================
    PART 2 — LOGO / SOCIAL
  ======================================================{%- endcomment -%}
  <div class="jci-footer__brand">
    <div class="jci-footer__wrap">

      <div class="jci-footer__logo-wrap">
        {%- if section.settings.logo != blank -%}
          <img
            src="{{ section.settings.logo | image_url: width: 1600 }}"
            alt="{{ section.settings.logo.alt | default: shop.name | escape }}"
            class="jci-footer__logo-img"
            width="{{ section.settings.logo_max_width }}"
            height="auto"
            loading="lazy"
          >
        {%- else -%}
          <span class="jci-footer__logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </div>

      {%- assign jci_has_social = false -%}
      {%- if section.settings.social_facebook != blank
          or section.settings.social_instagram != blank
          or section.settings.social_linkedin != blank
          or section.settings.social_youtube != blank
          or section.settings.social_twitter != blank -%}
        {%- assign jci_has_social = true -%}
      {%- endif -%}

      {%- if jci_has_social -%}
        <nav class="jci-footer__social" aria-label="Social media">

          {%- if section.settings.social_facebook != blank -%}
            <a href="{{ section.settings.social_facebook }}" class="jci-footer__social-btn" aria-label="Facebook" target="_blank" rel="noopener noreferrer">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
              </svg>
            </a>
          {%- endif -%}

          {%- if section.settings.social_instagram != blank -%}
            <a href="{{ section.settings.social_instagram }}" class="jci-footer__social-btn" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
              </svg>
            </a>
          {%- endif -%}

          {%- if section.settings.social_linkedin != blank -%}
            <a href="{{ section.settings.social_linkedin }}" class="jci-footer__social-btn" aria-label="LinkedIn" target="_blank" rel="noopener noreferrer">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
                <rect x="2" y="9" width="4" height="12"/>
                <circle cx="4" cy="4" r="2"/>
              </svg>
            </a>
          {%- endif -%}

          {%- if section.settings.social_youtube != blank -%}
            <a href="{{ section.settings.social_youtube }}" class="jci-footer__social-btn" aria-label="YouTube" target="_blank" rel="noopener noreferrer">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path fill="currentColor" d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/>
                <polygon fill="white" points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/>
              </svg>
            </a>
          {%- endif -%}

          {%- if section.settings.social_twitter != blank -%}
            <a href="{{ section.settings.social_twitter }}" class="jci-footer__social-btn" aria-label="Twitter / X" target="_blank" rel="noopener noreferrer">
              <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
                <path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"/>
              </svg>
            </a>
          {%- endif -%}

        </nav>
      {%- endif -%}

    </div>
  </div>

  {%- comment -%}====== DIVIDER 2 ======{%- endcomment -%}
  <div class="jci-footer__divider"></div>

  {%- comment -%}======================================================
    PART 3 — LEGAL BAR
  ======================================================{%- endcomment -%}
  <div class="jci-footer__legal">
    <div class="jci-footer__wrap">
      <div class="jci-footer__legal-row">

        {%- unless section.settings.copyright == blank -%}
          <p class="jci-footer__copyright">{{ section.settings.copyright }}</p>
        {%- endunless -%}

        {%- if section.settings.terms_label != blank or section.settings.refund_label != blank or section.settings.privacy_label != blank -%}
          <nav class="jci-footer__policy-nav" aria-label="Legal links">
            <ul class="jci-footer__policy-list" role="list">
              {%- if section.settings.terms_label != blank -%}
                <li>
                  <a href="{{ section.settings.terms_url | default: '#' }}" class="jci-footer__policy-link">
                    {{- section.settings.terms_label -}}
                  </a>
                </li>
              {%- endif -%}
              {%- if section.settings.refund_label != blank -%}
                <li>
                  <a href="{{ section.settings.refund_url | default: '#' }}" class="jci-footer__policy-link">
                    {{- section.settings.refund_label -}}
                  </a>
                </li>
              {%- endif -%}
              {%- if section.settings.privacy_label != blank -%}
                <li>
                  <a href="{{ section.settings.privacy_url | default: '#' }}" class="jci-footer__policy-link">
                    {{- section.settings.privacy_label -}}
                  </a>
                </li>
              {%- endif -%}
            </ul>
          </nav>
        {%- endif -%}

      </div>
    </div>
  </div>

</div>

{% schema %}
