      "default": "Refund Policy"
    },
    {
      "type": "url",
      "id": "refund_url",
      "label": "Refund URL"
    },
    {
      "type": "text",
      "id": "privacy_label",
      "label": "Privacy label",
      "default": "Privacy Policy"
    },
    {
      "type": "url",
      "id": "privacy_url",
      "label": "Privacy URL"
    }
  ],
  "blocks": [
    {
      "type": "nav_link",
      "name": "Shopping link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Link text",
          "default": "Link"
        },
        {
          "type": "url",
          "id": "url",
          "label": "URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "JCI Footer",
      "blocks": [
        { "type": "nav_link", "settings": { "label": "Contact Us" } },
        { "type": "nav_link", "settings": { "label": "My Account" } },
        { "type": "nav_link", "settings": { "label": "Returns & Refunds" } },
        { "type": "nav_link", "settings": { "label": "Shipping & Delivery" } },
        { "type": "nav_link", "settings": { "label": "Terms & Conditions" } },
        { "type": "nav_link", "settings": { "label": "Reviews" } },
        { "type": "nav_link", "settings": { "label": "Sitemap" } }
      ]
    }
  ]
}
{% endschema %}
