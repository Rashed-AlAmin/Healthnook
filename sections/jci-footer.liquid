    },
    {
      "type": "url",
      "id": "newsletter_privacy_link_url",
      "label": "Privacy link URL"
    },
    {
      "type": "text",
      "id": "newsletter_placeholder",
      "label": "Input placeholder",
      "default": "Newsletter sign-up..."
    },
    {
      "type": "text",
      "id": "newsletter_button",
      "label": "Subscribe button label",
      "default": "SUBSCRIBE"
    },
    {
      "type": "text",
      "id": "newsletter_success",
      "label": "Success message",
      "default": "Thank you for subscribing!"
    },
    {
      "type": "header",
      "content": "Shopping links"
    },
    {
      "type": "text",
      "id": "links_heading",
      "label": "Section heading",
      "default": "Shopping With Us"
    },
    {
      "type": "header",
      "content": "Contact card"
    },
    {
      "type": "text",
      "id": "contact_heading",
      "label": "Card heading",
      "default": "Contact Us"
    },
    {
      "type": "text",
      "id": "contact_phone_display",
      "label": "Phone number (display text)",
      "default": "02 9411 1433"
    },
    {
      "type": "text",
      "id": "contact_phone_href",
      "label": "Phone link (e.g. tel:+61294111433)",
      "default": "tel:+61294111433",
      "info": "Enter the full tel: link for click-to-call"
    },
    {
      "type": "text",
      "id": "contact_email_display",
      "label": "Email address (display text)",
      "default": "support@healthnook.com.au"
    },
    {
      "type": "text",
      "id": "contact_email_href",
      "label": "Email link (e.g. mailto:support@...)",
      "default": "mailto:support@healthnook.com.au",
      "info": "Enter the full mailto: link"
    },
    {
      "type": "text",
      "id": "contact_store_label",
      "label": "Store locator text",
      "default": "Find your nearest store"
    },
    {
      "type": "url",
